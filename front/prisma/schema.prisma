generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
    provider = "mongodb"
    url      = env("DATABASE_URL")
}

model PostSkeleton {
    id        String  @id @default(auto()) @map("_id") @db.ObjectId
    repo_name String
    title     String
    body      String
    commits   String
    isUsed    Boolean @default(false)
}

model BlogPost {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    slug      String   @unique
    title     String
    excerpt   String
    date      String
    tags      String[]
    readTime  Int
    cover     String
    mainPage  Boolean
    type      String
    lang      String   @default("en")
    status    String   @default("draft")
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Project {
    id           String   @id @default(auto()) @map("_id") @db.ObjectId
    name         String
    slug         String
    link         String
    image        String?
    order        Int?
    isDeveloping Boolean  @default(false)
    isArchived   Boolean  @default(false)
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    stackIDs String[]    @db.ObjectId
    stack    HomeSkill[] @relation(fields: [stackIDs], references: [id])
}

model HomeHero {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    title     String
    subtitle  String
    lang      String   @unique @default("en")
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model HomeAbout {
    id        String          @id @default(auto()) @map("_id") @db.ObjectId
    image     String
    key       String          @unique @default("main")
    createdAt DateTime        @default(now())
    updatedAt DateTime        @updatedAt
    text      HomeAboutText[]
}

model HomeAboutText {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    text      String
    lang      String   @unique @default("en")
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    homeAbout   HomeAbout @relation(fields: [homeAboutId], references: [id])
    homeAboutId String    @db.ObjectId
}

model HomeExperience {
    id               String   @id @default(auto()) @map("_id") @db.ObjectId
    company          String
    position         String
    startDate        DateTime
    endDate          DateTime
    isPresent        Boolean  @default(false)
    responsibilities String
    order            Int?
    lang             String   @default("en")
    createdAt        DateTime @default(now())
    updatedAt        DateTime @updatedAt

    stackIDs String[]    @db.ObjectId
    stack    HomeSkill[] @relation(fields: [stackIDs], references: [id])
}

model HomeSkill {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    icon      String
    label     String
    order     Int      @default(0)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    homeExperienceIDs String[]         @db.ObjectId
    homeExperience    HomeExperience[] @relation(fields: [homeExperienceIDs], references: [id])

    projectId String[]  @db.ObjectId
    project   Project[] @relation(fields: [projectId], references: [id])
}

model SettingsSeo {
    id    String @id @default(auto()) @map("_id") @db.ObjectId
    image String
    key   String @unique @default("main")

    content SettingsSeoContent[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model SettingsSeoContent {
    id String @id @default(auto()) @map("_id") @db.ObjectId

    title       String
    description String
    link        String
    author      String
    lang        String @unique @default("en")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    settingsSeo   SettingsSeo? @relation(fields: [settingsSeoId], references: [id])
    settingsSeoId String?      @db.ObjectId
}

model SettingsContacts {
    id String @id @default(auto()) @map("_id") @db.ObjectId

    name String
    link String

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model SettingsScripts {
    id String @id @default(auto()) @map("_id") @db.ObjectId

    type      String
    innerHTML String
    async     Boolean
    body      Boolean

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
