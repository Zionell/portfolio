generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
    provider = "mongodb"
    url      = env("DATABASE_URL")
}

model PostSkeleton {
    id        String  @id @default(auto()) @map("_id") @db.ObjectId
    repo_name String
    title     String
    body      String
    commits   String
    isUsed    Boolean @default(false)
}

model Posts {
    id          String        @id @default(auto()) @map("_id") @db.ObjectId
    slug        String        @unique
    title       String
    excerpt     String
    date        String
    tags        String[]
    content     PostContent[]
    readTime    Int
    cover       String?
    mainPage    Boolean       @default(false)
    isPublished Boolean       @default(false)
    lang        String        @default("en")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    type   PostsType @relation(fields: [typeId], references: [id])
    typeId String    @db.ObjectId
}

model PostContent {
    id    String  @id @default(auto()) @map("_id") @db.ObjectId
    text  String?
    image String?
    video String?
    order Int     @default(0)

    posts   Posts?  @relation(fields: [postsId], references: [id])
    postsId String? @db.ObjectId

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model PostsType {
    id       String @id @default(auto()) @map("_id") @db.ObjectId
    label_ru String
    label_en String

    posts Posts[]
}

model Project {
    id             String   @id @default(auto()) @map("_id") @db.ObjectId
    name           String
    slug           String
    link           String
    image          String?
    description_ru String?
    description_en String?
    order          Int?
    isDeveloping   Boolean  @default(false)
    isArchived     Boolean  @default(false)
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt

    stackIDs String[]    @db.ObjectId
    stack    HomeSkill[] @relation(fields: [stackIDs], references: [id])
}

model HomeHero {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    title     String
    subtitle  String
    lang      String   @unique @default("en")
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model HomeAbout {
    id        String          @id @default(auto()) @map("_id") @db.ObjectId
    image     String
    key       String          @unique @default("main")
    createdAt DateTime        @default(now())
    updatedAt DateTime        @updatedAt
    text      HomeAboutText[]
}

model HomeAboutText {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    text      String
    lang      String   @unique @default("en")
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    homeAbout   HomeAbout @relation(fields: [homeAboutId], references: [id])
    homeAboutId String    @db.ObjectId
}

model HomeExperience {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    startDate DateTime
    endDate   DateTime @default(now())
    isPresent Boolean  @default(false)
    order     Int?

    company_en          String
    company_ru          String
    position_en         String
    position_ru         String
    responsibilities_en String
    responsibilities_ru String

    stackIDs String[]    @db.ObjectId
    stack    HomeSkill[] @relation(fields: [stackIDs], references: [id])

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model HomeSkill {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    icon      String
    label     String
    order     Int      @default(0)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    homeExperienceIDs String[]         @db.ObjectId
    homeExperience    HomeExperience[] @relation(fields: [homeExperienceIDs], references: [id])

    projectId String[]  @db.ObjectId
    project   Project[] @relation(fields: [projectId], references: [id])
}

model SettingsSeo {
    id    String @id @default(auto()) @map("_id") @db.ObjectId
    image String
    key   String @unique @default("main")

    content SettingsSeoContent[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model SettingsSeoContent {
    id String @id @default(auto()) @map("_id") @db.ObjectId

    title       String
    description String
    link        String
    author      String
    lang        String @unique @default("en")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    settingsSeo   SettingsSeo? @relation(fields: [settingsSeoId], references: [id])
    settingsSeoId String?      @db.ObjectId
}

model SettingsContacts {
    id String @id @default(auto()) @map("_id") @db.ObjectId

    name String
    link String
    icon String

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model SettingsScripts {
    id String @id @default(auto()) @map("_id") @db.ObjectId

    type      String
    innerHTML String
    async     Boolean
    body      Boolean

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model ContactsHero {
    id String @id @default(auto()) @map("_id") @db.ObjectId

    title    String
    subTitle String
    location String
    focus    String[]

    cvLink     String
    cvFileName String

    lang String @unique @default("en")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model ContactsRequests {
    id String @id @default(auto()) @map("_id") @db.ObjectId

    name    String
    email   String
    message String
    isRead  Boolean

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
