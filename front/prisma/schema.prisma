generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
    provider = "mongodb"
    url      = env("DATABASE_URL")
}

model PostSkeleton {
    id        String @id @default(auto()) @map("_id") @db.ObjectId
    repo_name String
    title     String
    body      String
    commits   String
}

model BlogPost {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    slug      String   @unique
    title     String
    excerpt   String
    date      String
    tags      String[]
    readTime  Int
    cover     String
    mainPage  Boolean
    type      String
    lang      String   @default("en")
    status    String   @default("draft")
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Project {
    id           String   @id @default(auto()) @map("_id") @db.ObjectId
    name         String
    slug         String   @unique
    link         String
    stack        String[]
    order        Int?
    lang         String   @default("en")
    isDeveloping Boolean  @default(false)
    isArchived   Boolean  @default(false)
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt
}

model HomeHero {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    title     String
    subtitle  String
    lang      String   @unique @default("en")
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model HomeAbout {
    id        String          @id @default(auto()) @map("_id") @db.ObjectId
    image     String
    key       String          @unique @default("main")
    createdAt DateTime        @default(now())
    updatedAt DateTime        @updatedAt
    text      HomeAboutText[]
}

model HomeAboutText {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    text      String
    lang      String   @unique @default("en")
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    homeAbout   HomeAbout @relation(fields: [homeAboutId], references: [id])
    homeAboutId String    @db.ObjectId
}

model HomeExperience {
    id               String   @id @default(auto()) @map("_id") @db.ObjectId
    company          String
    position         String
    period           String
    stack            String[]
    responsibilities String[]
    order            Int?
    lang             String   @default("en")
    createdAt        DateTime @default(now())
    updatedAt        DateTime @updatedAt
}

model HomeSkill {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    icon      String
    label     String
    order     Int?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model Settings {
    id        String   @id @default(auto()) @map("_id") @db.ObjectId
    key       String   @unique
    contacts  Json?
    seo       Json?
    meta      Json?
    links     Json?
    scripts   Json[]
    noScripts Json[]
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
